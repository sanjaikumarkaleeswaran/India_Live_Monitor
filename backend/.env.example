NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smart_india_monitor?retryWrites=true&w=majority

# JWT Secrets (use strong random strings — min 64 chars)
JWT_ACCESS_SECRET=your_super_secret_access_token_key_minimum_64_characters_here
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_minimum_64_characters_here
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Client Origin (for CORS)
CLIENT_ORIGIN=http://localhost:5173

# Email (for future email verification — using Nodemailer + Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# External APIs (all free tiers)
OPENWEATHER_API_KEY=your_openweathermap_api_key
AQICN_API_KEY=your_aqicn_api_key
NEWS_API_KEY=your_newsapi_key
